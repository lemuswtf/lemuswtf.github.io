<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LemusWTF</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,Helvetica,sans-serif;
}

body{
background:linear-gradient(-45deg,#0f172a,#1e3a8a,#6d28d9,#111827);
background-size:400% 400%;
animation:fondo 12s ease infinite;
color:#fff;
text-align:center;
overflow-x:hidden;
}

@keyframes fondo{
0%{background-position:0% 50%;}
50%{background-position:100% 50%;}
100%{background-position:0% 50%;}
}

header{
padding:30px;
}

.logo{
width:140px;
height:140px;
margin:auto;
border-radius:50%;
background:linear-gradient(135deg,#00e5ff,#7c3aed);
display:flex;
justify-content:center;
align-items:center;
font-size:55px;
font-weight:bold;
box-shadow:0 0 40px #00e5ff;
animation:flotar 3s ease-in-out infinite;
}

@keyframes flotar{
50%{transform:translateY(-12px);}
}

h1{
font-size:60px;
margin-top:20px;
text-shadow:0 0 20px #00e5ff;
}

p{
font-size:20px;
margin:20px;
color:#ddd;
}

.boton{
display:inline-block;
padding:15px 35px;
background:#00e5ff;
color:#000;
font-weight:bold;
border-radius:30px;
text-decoration:none;
transition:.3s;
}

.boton:hover{
transform:scale(1.08);
box-shadow:0 0 25px #00e5ff;
}

section{
max-width:900px;
margin:auto;
padding:60px 20px;
}

.tarjetas{
display:flex;
flex-wrap:wrap;
justify-content:center;
gap:20px;
margin-top:30px;
}

.card{
background:rgba(255,255,255,.08);
backdrop-filter:blur(10px);
padding:25px;
width:260px;
border-radius:20px;
transition:.3s;
}

.card:hover{
transform:translateY(-10px);
box-shadow:0 0 20px #00e5ff;
}

footer{
padding:30px;
color:#bbb;
}
</style>

</head>

<body>

<header>

<div class="logo">LW</div>

<h1>LemusWTF</h1>

<p>Bienvenido a mi sitio web oficial.</p>

<a class="boton" href="#">Explorar</a>

</header>

<section>

<h2>Mis Proyectos</h2>

<div class="tarjetas">

<div class="card">
<h3>🌐 Web</h3>
<p>Sitios modernos y rápidos.</p>
</div>

<div class="card">
<h3>🎮 Gaming</h3>
<p>Contenido y comunidad.</p>
</div>

<div class="card">
<h3>🚀 Próximamente</h3>
<p>Más novedades muy pronto.</p>
</div>

</div>

</section>

<footer>

© 2026 LemusWTF

</footer>

</body>
</html>